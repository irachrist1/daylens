    desktop --> errors
    desktop --> traces
    web --> errors
    web --> traces
    convex --> errors
    convex --> traces
    web --> replay

    desktop --> analytics
    web --> analytics
    convex --> analytics

    flags --> phased
    flags --> rollback

    ci --> preview --> smoke --> phased
    releases --> phased
    errors --> rollback
    traces --> rollback
    analytics --> phased

