flowchart LR
    subgraph clients[Client Entry Points]
        desktop[Desktop AI Surface]
        web[Web AI Surface]
    end

    subgraph contract[Shared Daylens AI Contract]
        prompts[Prompt + Answer Contract]
        router[Deterministic Router]
        context[Context Assembler]
        modelroute[Per-Job Model Routing]
        prompts --> router --> context --> modelroute
    end

    subgraph evidence[Evidence Adapters]
        local[Local Evidence Adapter]
        cloud[Cloud Evidence Adapter]
    end

    subgraph providers[Provider Tier]
        fast[Fast Tier\nHaiku / GPT-5.4-mini]
        chat[Interactive Tier\nSonnet / GPT-5.4]
        deep[Deep Tier\nOpus / GPT-5.4-pro]
    end

    subgraph persistence[Daylens-Owned Persistence]
        threads[(Threads + Messages)]
        artifacts[(Artifacts + Files)]
        jobs[(AI Jobs + Usage Metrics)]
    end

    streamed[Streamed Answer / Report / Artifact]

    desktop --> prompts
    web --> prompts

    local --> context
    cloud --> context

    modelroute --> fast
    modelroute --> chat
    modelroute --> deep

    fast --> streamed
    chat --> streamed
    deep --> streamed

    streamed --> threads
    streamed --> artifacts
    modelroute --> jobs

