DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daylens
PUBLIC_BASE_URL=https://billing.daylens.app
PORT=8787
NODE_ENV=production
SESSION_SECRET=replace-with-32-random-bytes
INSTALLATION_HASH_SECRET=replace-with-another-random-secret
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-litellm-master
LITELLM_KEY_ENCRYPTION_SECRET=replace-with-32-random-bytes
DAYLENS_MANAGED_PROVIDER=anthropic
# Real upstream model LiteLLM proxies to. litellm-config.yaml reads this as the model
# behind the `daylens-default` alias. Set it to the model you actually resell.
DAYLENS_MANAGED_MODEL=anthropic/claude-sonnet-4-6
# Public alias the billing server sends to LiteLLM. MUST equal a `model_name` in
# litellm-config.yaml. Leave as-is unless you rename the model_name in the yaml too.
LITELLM_MODEL_ALIAS=daylens-default
DAYLENS_PROVIDER_API_KEY=
SUBSCRIPTION_FAIR_USE_USD=20
POLAR_API_BASE_URL=https://api.polar.sh/v1
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=https://daylens.app/billing/success
CHECKOUT_RETURN_URL=https://daylens.app/billing
FLUTTERWAVE_API_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_LOCAL_PASS_RWF=15000
# Intercom (Fin). Only the App ID is public (it ships in the widget URL); every
# other value is a secret and must exist ONLY here — never in the desktop client.
# IV secret: Intercom dashboard -> Settings -> Security -> Identity verification.
INTERCOM_APP_ID=y4l8ype0
INTERCOM_IDENTITY_VERIFICATION_SECRET=
INTERCOM_ACCESS_TOKEN=
INTERCOM_OAUTH_CLIENT_ID=
INTERCOM_OAUTH_CLIENT_SECRET=
