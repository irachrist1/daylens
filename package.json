{
  "name": "daylens",
  "productName": "Daylens",
  "version": "1.0.45",
  "description": "Cross-platform activity tracker that turns your laptop history into a searchable, AI-ready work timeline.",
  "main": ".vite/build/main.js",
  "workspaces": [
    "apps/web",
    "packages/*",
    "services/billing"
  ],
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"packages/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"packages/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "depcheck": "depcheck",
    "contract:check": "node scripts/check-remote-contract.mjs",
    "web:dev": "npm --prefix apps/web run dev",
    "web:typecheck": "npm --prefix apps/web run typecheck",
    "web:build": "npm --prefix apps/web run build",
    "web:contract:check": "npm --prefix apps/web run contract:check",
    "test": "node scripts/run-tests.mjs",
    "test:notifications": "DAYLENS_REAL_ELECTRON=1 ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs scripts/fire-test-notifications.mjs",
    "test:real-world": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs --test ./tests/realWorldActivityFlow.test.ts",
    "test:ai-chat": "node scripts/run-tests.mjs aiTurnEndToEnd chatAgentStreaming citations aiActions followUpSuggestions voiceContract aiThread",
    "verify:ai-turn": "node scripts/run-tests.mjs aiTurnEndToEnd",
    "verify:synthetic-day": "node scripts/run-tests.mjs syntheticDay privacyPropagation",
    "real-day:prepare": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./scripts/real-day/run.ts prepare",
    "verify:real-day": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./scripts/real-day/run.ts evaluate",
    "verify:real-day:desktop": "node ./scripts/real-day/desktop.mjs",
    "real-day:accept": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./scripts/real-day/run.ts accept",
    "verify:remote-web": "node scripts/run-tests.mjs webRemoteRoundtrip webBehavior",
    "verify:shipping": "npm run typecheck && npm run lint && npm test && npm run verify:synthetic-day && npm run verify:ai-turn && npm run verify:remote-web && npm run timeline:eval -- --strict && npm run contract:check && npm run web:contract:check && npm --prefix apps/web run manifest:check && npm run web:typecheck && npm run web:build && npm run billing:check && npm run billing:sandbox && npm run build:all",
    "wrapped:bench": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs --test ./tests/wrappedBenchmark.test.ts",
    "wrapped:bench:run": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./tests/wrapped-bench/run.ts",
    "test:behaviour": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./tests/ai-behaviour/run.ts",
    "timeline:eval": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs ./tests/timeline-eval/run.ts",
    "bench:queries": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs ./scripts/benchmark-year-queries.ts",
    "billing:check": "node --check services/billing/src/server.mjs",
    "billing:entitlement-key": "node services/billing/scripts/generate-entitlement-key.mjs",
    "billing:sandbox": "node services/billing/sandbox/run.mjs",
    "billing:e2e": "node services/billing/sandbox/run.mjs",
    "timeline": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./tests/ai-behaviour/show-timeline.ts",
    "trace": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./tests/ai-behaviour/show-trace.ts",
    "moment:bench": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader-real.mjs ./tests/moment-bench/run.ts",
    "build:main": "cross-env STANDALONE_BUILD=1 vite build --config vite.main.config.ts",
    "build:preload": "cross-env STANDALONE_BUILD=1 vite build --config vite.preload.config.ts",
    "build:renderer": "cross-env STANDALONE_BUILD=1 vite build --config vite.renderer.config.ts",
    "build:mcp": "vite build --config vite.mcp.config.ts",
    "build:capture-helper": "bash scripts/build-capture-helper.sh",
    "models:semantic": "node scripts/download-semantic-model.mjs",
    "build:all": "npm run build:main && npm run build:preload && npm run build:renderer && npm run build:mcp && npm run build:capture-helper",
    "dist:win": "npm run build:all && electron-builder --win --config electron-builder.config.js",
    "dist:win:store": "npm run build:all && electron-builder --win appx --config electron-builder.config.js --publish never",
    "dist:mac": "npm run build:all && electron-builder --mac zip dmg --config electron-builder.config.js",
    "dist:linux": "npm run build:all && electron-builder --linux AppImage deb rpm tar.gz --config electron-builder.config.js",
    "postinstall": "node scripts/rebuild-natives.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.96",
    "@ai-sdk/google": "^3.0.91",
    "@ai-sdk/mcp": "^1.0.61",
    "@ai-sdk/openai": "^3.0.84",
    "@ai-sdk/openai-compatible": "^2.0.59",
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/genai": "^1.47.0",
    "@huggingface/transformers": "3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@paymoapp/active-window": "^2.1.4",
    "@sentry/electron": "^7.11.0",
    "ai": "^6.0.224",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "keytar": "^7.9.0",
    "lucide-react": "^1.8.0",
    "openai": "^6.33.0",
    "posthog-node": "^5.28.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.0.0",
    "depcheck": "^1.4.7",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "js-yaml": "^4.1.0",
    "knip": "^6.15.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0"
  },
  "overrides": {
    "lodash": "4.18.1",
    "protobufjs": "7.5.9"
  }
}
